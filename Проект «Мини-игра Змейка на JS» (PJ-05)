body {
    font-family: Arial, sans-serif;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
    margin: 0;
    background-color: #f0f0f0;
}

.game-container {
    text-align: center;
}

.score-panel {
    margin-bottom: 20px;
    font-size: 1.2em;
}

#high-score-container {
    display: none;
}

.game-field {
    display: grid;
    grid-template-columns: repeat(10, 40px);
    grid-template-rows: repeat(10, 40px);
    gap: 2px;
    background-color: #333;
    padding: 10px;
    border-radius: 5px;
    margin: 0 auto;
}

.cell {
    width: 40px;
    height: 40px;
    background-color: #222;
    border-radius: 3px;
}

.snake {
    background-color: #4CAF50;
    border-radius: 50%;
}

.apple {
    background-color: #F44336;
    border-radius: 50%;
    position: relative;
}

.apple::after {
    content: '';
    position: absolute;
    top: 5px;
    left: 12px;
    width: 6px;
    height: 8px;
    background-color: #8B4513;
    border-radius: 2px;
}

.restart-container {
    margin-top: 20px;
}

button {
    padding: 10px 20px;
    font-size: 1em;
    cursor: pointer;
    background-color: #4CAF50;
    color: white;
    border: none;
    border-radius: 5px;
}

button:hover {
    background-color: #45a049;
}
class GameField {
    constructor(size = 10) {
        this._size = size;
        this._fieldElement = document.getElementById('game-field');
        this._cells = [];
        this._initializeField();
    }

    _initializeField() {
        this._fieldElement.innerHTML = '';
        this._cells = [];

        for (let y = 0; y < this._size; y++) {
            for (let x = 0; x < this._size; x++) {
                const cell = document.createElement('div');
                cell.className = 'cell';
                cell.dataset.x = x;
                cell.dataset.y = y;
                this._fieldElement.appendChild(cell);
                this._cells.push(cell);
            }
        }
    }

    getCell(x, y) {
        const index = y * this._size + x;
        return this._cells[index];
    }

    clearCell(x, y) {
        const cell = this.getCell(x, y);
        if (cell) {
            cell.className = 'cell';
        }
    }

    setCellClass(x, y, className) {
        const cell = this.getCell(x, y);
        if (cell) {
            cell.className = `cell ${className}`;
        }
    }

    getSize() {
        return this._size;
    }
}

class Snake {
    constructor() {
        this._body = [];
        this._direction = { x: 1, y: 0 };
        this._nextDirection = { x: 1, y: 0 };
    }

    initialize(startX, startY) {
        this._body = [
            { x: startX, y: startY },
            { x: startX - 1, y: startY }
        ];
        this._direction = { x: 1, y: 0 };
        this._nextDirection = { x: 1, y: 0 };
    }

    updateDirection(newDirection) {
        // Запрещаем разворот на 180 градусов
        if (this._direction.x + newDirection.x !== 0 &&
            this._direction.y + newDirection.y !== 0) {
            this._nextDirection = newDirection;
        }
    }

    move() {
        this._direction = this._nextDirection;

        const head = this._body[0];
        let newX = head.x + this._direction.x;
        let newY = head.y + this._direction.y;

        // Прохождение сквозь стены
        newX = (newX + this._body.length) % this._body.length;
        newY = (newY + this._body.length) % this._body.length;

        const newHead = { x: newX, y: newY };
        this._body.unshift(newHead);
    }

    grow() {
        // При поедании яблока просто не удаляем последний сегмент
    }

    checkCollision() {
        const head = this._body[0];

        // Проверка столкновения с собой
        for (let i = 1; i < this._body.length; i++) {
            if (head.x === this._body[i].x && head.y === this._body[i].y) {
                return true;
            }
        }
        return false;
    }

    getBody() {
        return [...this._body];
    }

    getHead() {
        return this._body[0];
    }
}

class Apple {
    constructor() {
        this._position = { x: 0, y: 0 };
    }

    spawn(snakeBody, fieldSize) {
        let newPosition;
        do {
            newPosition = {
                x: Math.floor(Math.random() * fieldSize),
                y: Math.floor(Math.random() * fieldSize)
            };
        } while (snakeBody.some(segment =>
            segment.x === newPosition.x && segment.y === newPosition.y
        ));

        this._position = newPosition;
    }

    getPosition() {
        return { ...this._position };
    }
}

